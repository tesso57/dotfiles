#!/usr/bin/env bash
set -euo pipefail

# cmux-delegate: AI エージェント委任ロジック
# cmux の IPC プリミティブを組み合わせて、別ペインでエージェントを起動・監視・結果収集する

SCRIPT_NAME="$(basename "$0")"
DEFAULT_TIMEOUT=900

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME <subcommand> [args...]

Subcommands:
  start <agent> <prompt>                          ワークスペース作成 + エージェント起動
  wait <task_id> [timeout] [surface_ref] [agent_type]
                                                  完了シグナルをブロック待ち (default: ${DEFAULT_TIMEOUT}s)
                                                  タイムアウト時は probe で 1 回フォールバック
  wait-poll <task_id> [timeout] [interval] [surface_ref] [agent_type]
                                                  ポーリング待機 + 進捗出力 (レガシー)
  probe <task_id> [surface_ref] [agent_type]      エージェント状態を判定 (completed/active/idle/waiting/frozen/stalled/unknown)
  read <task_id> [surface_ref] [lines]            結果読取 (.result → .out → screen の優先順)
  status <task_id> <msg> [icon]                   サイドバーステータス更新
  cleanup <task_id> [surface_ref] [grace_period]  一時ファイル削除 + ペイン閉鎖

Agents:
  claude    Claude Code (インタラクティブ)
  codex     Codex CLI (インタラクティブ)
  gemini    Gemini CLI ワンショット (gemini -p)
  cmd       任意コマンド ワンショット
EOF
  exit 1
}

generate_task_id() {
  echo "delegate-$(date +%s)-$$"
}

# --- start ---
cmd_start() {
  local agent="${1:?agent type required (claude/codex/gemini/cmd)}"
  local prompt="${2:?prompt required}"
  local task_id
  task_id="$(generate_task_id)"

  local prompt_file="/tmp/${task_id}.prompt"
  local launcher="/tmp/${task_id}.sh"
  local outfile="/tmp/${task_id}.out"

  # プロンプトをファイルに書き出し（エスケープ問題を回避）
  printf '%s' "$prompt" > "$prompt_file"

  # ランチャースクリプト生成
  case "$agent" in
    claude)
      cat > "$launcher" << 'LAUNCHER_EOF'
#!/bin/bash
set -euo pipefail
TASK_ID="__TASK_ID__"
PROMPT=$(cat "/tmp/${TASK_ID}.prompt")

# 結果ファイル書き出し指示をプロンプト末尾に追加（codex と同じ方式）
FULL_PROMPT="あなたは orchestrator から委任されたワーカーエージェントです。以下の2ステップで進めてください。

## Step 1: タスクを実行
${PROMPT}

## Step 2: 結果を報告
タスク完了後、orchestrator が結果を収集できるよう、以下のコマンドで結果ファイルを書き出してください。これが orchestrator への報告になります。Step 2 を実行するまでタスクは完了とみなされません。

cat > /tmp/${TASK_ID}.result << 'RESULT_EOF'
（ここに結果サマリーを記述）
RESULT_EOF

良い報告の例:
cat > /tmp/example.result << 'RESULT_EOF'
## 完了サマリー
### 実施した作業
- UserService の CreateUser メソッドを実装
- バリデーションロジックを追加

### 作成・変更したファイル
- pkg/service/user.go（新規作成）
- pkg/handler/user_handler.go（新規作成）

### ビルド/テスト結果
- go build ./... OK
- go test ./pkg/service/... OK（3 tests passed）

### 注意点
- DB マイグレーションは未実施
RESULT_EOF"

claude "$FULL_PROMPT" \
  --permission-mode acceptEdits \
  --allowedTools 'Bash(cat > /tmp/*)' \
  --add-dir /tmp || true
LAUNCHER_EOF
      ;;
    codex)
      cat > "$launcher" << 'LAUNCHER_EOF'
#!/bin/bash
set -euo pipefail
TASK_ID="__TASK_ID__"
PROMPT=$(cat "/tmp/${TASK_ID}.prompt")

# 結果ファイル書き出し指示をプロンプト末尾に追加
FULL_PROMPT="${PROMPT}

[IMPORTANT] タスク完了後、結果のサマリーを以下のBashコマンドで /tmp/${TASK_ID}.result に書き出してください:
cat > /tmp/${TASK_ID}.result << 'RESULT_EOF'
（ここに結果サマリーを記述）
RESULT_EOF"

codex "$FULL_PROMPT" || true
LAUNCHER_EOF
      ;;
    gemini)
      cat > "$launcher" << 'LAUNCHER_EOF'
#!/bin/bash
set -euo pipefail
TASK_ID="__TASK_ID__"
# EXIT トラップで確実に完了通知（ペインが閉じられても発火する）
trap 'touch "/tmp/${TASK_ID}.done"; cmux wait-for -S "${TASK_ID}-done" 2>/dev/null || true' EXIT
PROMPT=$(cat "/tmp/${TASK_ID}.prompt")
gemini -p "$PROMPT" 2>&1 | tee "/tmp/${TASK_ID}.out"
LAUNCHER_EOF
      ;;
    cmd)
      cat > "$launcher" << 'LAUNCHER_EOF'
#!/bin/bash
set -euo pipefail
TASK_ID="__TASK_ID__"
# EXIT トラップで確実に完了通知（ペインが閉じられても発火する）
trap 'touch "/tmp/${TASK_ID}.done"; cmux wait-for -S "${TASK_ID}-done" 2>/dev/null || true' EXIT
CMD=$(cat "/tmp/${TASK_ID}.prompt")
eval "$CMD" 2>&1 | tee "/tmp/${TASK_ID}.out"
LAUNCHER_EOF
      ;;
    *)
      echo "Error: unknown agent type '$agent'. Use claude/codex/gemini/cmd." >&2
      exit 1
      ;;
  esac

  # 現在のワークスペース内に新しいペインを作成
  local split_output
  split_output="$(cmux --id-format refs new-pane)"
  local surface_ref
  surface_ref="$(echo "$split_output" | grep -o 'surface:[0-9]*' | head -1)"

  if [[ -z "$surface_ref" ]]; then
    echo "Error: failed to extract surface ref from: $split_output" >&2
    exit 1
  fi

  # プレースホルダーを実際の値で置換
  sed -i '' -e "s/__TASK_ID__/$task_id/g" "$launcher"
  chmod +x "$launcher"

  # ランチャーを送信して実行（\n で Enter 送信）
  cmux send --surface "$surface_ref" "/tmp/${task_id}.sh\n"

  # ステータス更新
  cmux set-status "$task_id" "Running ($agent)" --icon "▶️" 2>/dev/null || true

  # 結果を出力
  echo "TASK_ID=$task_id"
  echo "SURFACE_REF=$surface_ref"
}

# --- probe ---
# エージェントが動作中か・フリーズしているかを判定する
cmd_probe() {
  local task_id="${1:?task_id required}"
  local surface_ref="${2:-}"
  local agent_type="${3:-}"
  local outfile="/tmp/${task_id}.out"

  # 1. ファイルベース完了チェック（.done マーカーのみ）
  if [[ -f "/tmp/${task_id}.done" ]]; then
    echo "STATUS=completed"
    return 0
  fi

  # 2. cmux シグナル確認（即時チェック）
  if cmux wait-for "${task_id}-done" --timeout 0 2>/dev/null; then
    echo "STATUS=completed"
    return 0
  fi

  # 2. gemini/cmd: /tmp ファイルのサイズ変化で判定
  if [[ -f "$outfile" ]]; then
    local size1 size2
    size1=$(wc -c < "$outfile" 2>/dev/null || echo "0")
    sleep 3
    size2=$(wc -c < "$outfile" 2>/dev/null || echo "0")
    if [[ "$size1" != "$size2" ]]; then
      echo "STATUS=active"
    else
      echo "STATUS=stalled"
    fi
    return 0
  fi

  # 3. claude/codex: screen の変化で判定
  # 設計意図: probe は二次検出（フォールバック）。ランチャー内ポーリングが一次検出。
  # probe は wait-poll から呼ばれるため、ランチャーが検出できなかった場合の補完として機能する。
  if [[ -n "$surface_ref" ]]; then
    local screen1 screen2
    screen1=$(cmux read-screen --surface "$surface_ref" --lines 15 2>/dev/null || true)

    # 権限確認待ち検出（claude/codex 共通）
    # Allow プロンプトや y/n 確認が表示されている場合は waiting を返す。
    # frozen/idle より優先して判定し、権限待ちを誤って frozen 扱いしない。
    if echo "$screen1" | grep -qiE '(Allow .+\?|[Yy]/[Nn]|approve|permission)'; then
      echo "STATUS=waiting"
      return 0
    fi

    # インタラクティブ CLI 固有: プロンプト表示 + 作業インジケーターなし → idle
    if [[ "$agent_type" == "codex" ]]; then
      if echo "$screen1" | grep -q '›' && ! echo "$screen1" | grep -q 'Working'; then
        echo "STATUS=idle"
        return 0
      fi
    elif [[ "$agent_type" == "claude" ]]; then
      if echo "$screen1" | grep -q '❯' && ! echo "$screen1" | tail -5 | grep -qE '(⏺|Waiting|· )'; then
        echo "STATUS=idle"
        return 0
      fi
    fi

    sleep 5
    screen2=$(cmux read-screen --surface "$surface_ref" --lines 15 2>/dev/null || true)

    if [[ "$screen1" == "$screen2" ]]; then
      echo "STATUS=frozen"
    else
      echo "STATUS=active"
    fi
    return 0
  fi

  echo "STATUS=unknown"
  return 0
}

# --- wait-poll ---
# interval 秒ごとにポーリングしながら待機し、進捗を出力する
cmd_wait_poll() {
  local task_id="${1:?task_id required}"
  local total_timeout="${2:-$DEFAULT_TIMEOUT}"
  local interval="${3:-60}"
  local surface_ref="${4:-}"
  local agent_type="${5:-}"
  local start_seconds=$SECONDS

  cmux set-status "$task_id" "Polling..." --icon "⏳" 2>/dev/null || true

  while [[ $((SECONDS - start_seconds)) -lt $total_timeout ]]; do
    local elapsed=$((SECONDS - start_seconds))

    # probe で状態確認
    local status_line
    status_line=$(cmd_probe "$task_id" "$surface_ref" "$agent_type" 2>/dev/null || true)
    local status="${status_line#STATUS=}"

    echo "PROGRESS elapsed=${elapsed} status=${status}"

    case "$status" in
      completed|idle)
        cmux set-status "$task_id" "Done" --icon "✅" 2>/dev/null || true
        echo "OK"
        return 0
        ;;
      frozen)
        cmux set-status "$task_id" "Frozen" --icon "🥶" 2>/dev/null || true
        echo "FROZEN" >&2
        return 2
        ;;
      waiting)
        # 権限確認待ち — タイムアウトせず積極的に待機を継続
        cmux set-status "$task_id" "Permission wait" --icon "🔑" 2>/dev/null || true
        ;;
    esac

    # interval 秒待つか、done シグナルが来るかのどちらか
    if cmux wait-for "${task_id}-done" --timeout "$interval" 2>/dev/null; then
      cmux set-status "$task_id" "Done" --icon "✅" 2>/dev/null || true
      echo "PROGRESS elapsed=$((SECONDS - start_seconds)) status=completed"
      echo "OK"
      return 0
    fi
  done

  cmux set-status "$task_id" "Timeout" --icon "⏰" 2>/dev/null || true
  echo "TIMEOUT" >&2
  return 1
}

# --- wait ---
cmd_wait() {
  local task_id="${1:?task_id required}"
  local timeout="${2:-$DEFAULT_TIMEOUT}"
  local surface_ref="${3:-}"
  local agent_type="${4:-}"

  cmux set-status "$task_id" "Waiting..." --icon "⏳" 2>/dev/null || true

  # 短い間隔でシグナル待ち + ファイルチェック + プローブを繰り返す
  # cmux wait-for シグナルは届かないことがあるため、ファイルベースとプローブをフォールバックとする
  local start_seconds=$SECONDS
  local idle_count=0
  while [[ $((SECONDS - start_seconds)) -lt $timeout ]]; do
    # ファイルベース完了チェック（.done マーカーのみ — .result はエージェントが途中で書く可能性があるため使わない）
    if [[ -f "/tmp/${task_id}.done" ]]; then
      cmux set-status "$task_id" "Done" --icon "✅" 2>/dev/null || true
      echo "OK"
      return 0
    fi

    # インタラクティブ CLI の idle 検知
    # claude/codex はタスク完了後もプロセスが終了せずプロンプトに戻るだけのため、
    # 画面のプロンプト表示で完了を判定する。3回連続 idle で完了とみなす（誤検知防止）
    if [[ -n "$surface_ref" ]] && [[ "$agent_type" == "codex" || "$agent_type" == "claude" ]]; then
      local screen
      screen=$(cmux read-screen --surface "$surface_ref" --lines 10 2>/dev/null || true)

      local is_idle=false
      if [[ "$agent_type" == "codex" ]]; then
        # codex: › プロンプト + 作業インジケーターなし
        if echo "$screen" | grep -q '›' && ! echo "$screen" | grep -qE '(Working|Thinking|Searching)'; then
          is_idle=true
        fi
      elif [[ "$agent_type" == "claude" ]]; then
        # claude: ❯ プロンプト + ツール実行中インジケーターなし
        # ❯ は Claude Code の入力プロンプト。⏺ が最後の数行にあれば実行中。
        if echo "$screen" | grep -q '❯' && ! echo "$screen" | tail -5 | grep -qE '(⏺|Waiting|· )'; then
          is_idle=true
        fi
      fi

      if [[ "$is_idle" == "true" ]]; then
        idle_count=$((idle_count + 1))
        if [[ $idle_count -ge 3 ]]; then
          cmux set-status "$task_id" "Done (idle)" --icon "✅" 2>/dev/null || true
          echo "OK"
          return 0
        fi
      else
        idle_count=0
      fi
    fi

    # cmux シグナル待ち（最大15秒でタイムアウトし、ファイルを再チェック）
    local wait_chunk=15
    local remaining=$((timeout - (SECONDS - start_seconds)))
    if [[ $remaining -lt $wait_chunk ]]; then
      wait_chunk=$remaining
    fi
    if [[ $wait_chunk -le 0 ]]; then
      break
    fi

    if cmux wait-for "${task_id}-done" --timeout "$wait_chunk" 2>/dev/null; then
      cmux set-status "$task_id" "Done" --icon "✅" 2>/dev/null || true
      echo "OK"
      return 0
    fi
  done

  # タイムアウト → probe で 1 回だけ状態確認
  if [[ -n "$surface_ref" ]] || [[ -f "/tmp/${task_id}.out" ]]; then
    local status_line
    status_line=$(cmd_probe "$task_id" "$surface_ref" "$agent_type" 2>/dev/null || true)
    local status="${status_line#STATUS=}"

    case "$status" in
      completed|idle)
        cmux set-status "$task_id" "Done (late)" --icon "✅" 2>/dev/null || true
        echo "OK"
        return 0
        ;;
      active)
        # まだ動いている → 追加 60s 待機
        cmux set-status "$task_id" "Extra wait..." --icon "⏳" 2>/dev/null || true
        if cmux wait-for "${task_id}-done" --timeout 60 2>/dev/null; then
          cmux set-status "$task_id" "Done" --icon "✅" 2>/dev/null || true
          echo "OK"
          return 0
        fi
        ;;
    esac
  fi

  cmux set-status "$task_id" "Timeout" --icon "⏰" 2>/dev/null || true
  echo "TIMEOUT" >&2
  return 1
}

# --- read ---
cmd_read() {
  local task_id="${1:?task_id required}"
  local surface_ref="${2:-}"
  local lines="${3:-200}"
  local resultfile="/tmp/${task_id}.result"
  local outfile="/tmp/${task_id}.out"

  # 1. エージェントが書き出した結果ファイル（claude/codex）
  if [[ -f "$resultfile" ]] && [[ -s "$resultfile" ]]; then
    echo "SOURCE=result_file"
    cat "$resultfile"
    return 0
  fi

  # 2. stdout キャプチャファイル（gemini/cmd）
  if [[ -f "$outfile" ]] && [[ -s "$outfile" ]]; then
    echo "SOURCE=output_file"
    cat "$outfile"
    return 0
  fi

  # 3. スクリーンバッファ（フォールバック）
  if [[ -n "$surface_ref" ]]; then
    echo "SOURCE=screen_buffer"
    cmux read-screen --surface "$surface_ref" --scrollback --lines "$lines"
    return 0
  fi

  echo "Error: no result file, output file, or surface_ref available" >&2
  return 1
}

# --- status ---
cmd_status() {
  local task_id="${1:?task_id required}"
  local msg="${2:?message required}"
  local icon="${3:-📋}"

  cmux set-status "$task_id" "$msg" --icon "$icon"
}

# --- cleanup ---
cmd_cleanup() {
  local task_id="${1:?task_id required}"
  local surface_ref="${2:-}"
  local grace_period="${3:-0}"

  # grace_period が指定されていれば待つ
  if [[ "$grace_period" =~ ^[0-9]+$ ]] && [[ "$grace_period" -gt 0 ]]; then
    sleep "$grace_period"
  fi

  # 一時ファイル削除
  rm -f "/tmp/${task_id}.prompt" "/tmp/${task_id}.sh" "/tmp/${task_id}.out" "/tmp/${task_id}.result" "/tmp/${task_id}.done"

  # ステータスクリア
  cmux clear-status "$task_id" 2>/dev/null || true

  # ペイン（サーフェス）を閉じる
  if [[ -n "$surface_ref" ]]; then
    cmux close-surface --surface "$surface_ref" 2>/dev/null || true
  fi

  echo "Cleaned up $task_id"
}

# --- main ---
if [[ $# -lt 1 ]]; then
  usage
fi

subcommand="$1"
shift

case "$subcommand" in
  start)     cmd_start "$@" ;;
  wait)      cmd_wait "$@" ;;
  wait-poll) cmd_wait_poll "$@" ;;
  probe)     cmd_probe "$@" ;;
  read)      cmd_read "$@" ;;
  status)    cmd_status "$@" ;;
  cleanup)   cmd_cleanup "$@" ;;
  -h|--help|help) usage ;;
  *)
    echo "Error: unknown subcommand '$subcommand'" >&2
    usage
    ;;
esac
